# Exemplo de configuração de secrets para GitHub
# Copie este arquivo para secrets.toml e preencha com suas credenciais

# GitHub Personal Access Token
# Crie em: https://github.com/settings/tokens
# Permissões necessárias: repo (Full control of private repositories)
github_token = "ghp_YOUR_GITHUB_TOKEN_HERE"

# Nome completo do repositório (formato: username/repo-name)
github_repo = "seu-usuario/seu-repositorio"

# Caminho do arquivo JSON no repositório
github_file_path = "user_submissions.json"
